# ============================================
# MongoDB Configuration
# ============================================
# For local development:
MONGODB_URI=mongodb://localhost:27017/xpensetrack

# For MongoDB Atlas (production - get from https://cloud.mongodb.com):
# MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/xpensetrack?retryWrites=true&w=majority
# Replace: username, password, cluster0.xxxxx with your actual values

# ============================================
# JWT Configuration
# ============================================
# Generate a secure secret with: openssl rand -base64 32
# MUST be at least 256 bits (32 characters) for production
JWT_SECRET=your-secret-key-here-must-be-at-least-256-bits-long-change-in-production
JWT_EXPIRATION=604800000

# ============================================
# Server Configuration
# ============================================
# Local development
SERVER_PORT=8080

# For Render/Railway deployment (they set PORT automatically)
# PORT=8080
